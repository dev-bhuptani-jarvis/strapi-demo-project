{
  "kind": "collectionType",
  "collectionName": "product_categories",
  "info": {
    "singularName": "product-category",
    "pluralName": "product-categories",
    "displayName": "Product Category",
    "description": "Product category landing pages with repeatable product cards"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "categoryType": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "shortText": {
      "type": "text",
      "required": false
    },
    "products": {
      "type": "component",
      "repeatable": true,
      "component": "catalog.product-item"
    }
  }
}
